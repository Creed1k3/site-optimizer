{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Site Optimizer",
    "version": "0.5.0",
    "identifier": "dev.siteoptimizer",
    "build": {
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build",
        "devUrl": "http://localhost:1420",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [{
            "title": "Site Optimizer",
            "width": 1280,
            "height": 860,
            "minWidth": 1100,
            "minHeight": 760,
            "resizable": true,
            "fullscreen": false,
            "decorations": true,
            "transparent": false,
            "dragDropEnabled": true
        }],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "createUpdaterArtifacts": true,
        "resources": [
            "../sidecar/optimizer.js",
            "../sidecar/package.json",
            "../sidecar/package-lock.json",
            "../sidecar/node_modules"
        ],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk4Njg0RUEwMjY1RTVFQjgKUldTNFhsNG1vRTVvbUg5a2doNUQ4VlpyY0phajg2OE02YmJqcytqT2paenBHNkJ6ZlkzZE9hbjUK",
            "endpoints": [
                "https://github.com/Creed1k3/site-optimizer/releases/latest/download/latest.json"
            ]
        }
    }
}
